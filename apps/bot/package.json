		"dev": "tsc --watch"
	},
	"dependencies": {
		"@discordjs/core": "^2.3.0",
		"@questbot/database": "workspace:*",
		"@sapphire/framework": "^5.5.0",
		"@types/ms": "^2.1.0",
		"discord.js": "^14.24.0",
		"dotenv": "^17.4.2",
		"ms": "^2.1.3",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@sapphire/ts-config": "^5.0.1",
		"@types/node": "^22.18.8",
		"prettier": "^3.6.2",
		"rimraf": "^6.1.3",
		"typescript": "~5.9.3"
	},
	"engines": {
		"node": ">=22.12.0"
