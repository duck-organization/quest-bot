{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "@quest/bot",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "rimraf dist && prisma generate && tsc",
		"lint": "prettier --check . && eslint --ext .ts --format=pretty src",
		"format": "prettier --write . && eslint --ext .ts --fix --format=pretty src",
		"predev": "pnpm build",
		"start": "node --env-file-if-exists=../../.env dist/sharder.js",
		"dev": "concurrently \"tsc --watch\" \"node --watch --env-file-if-exists=../../.env dist/index.js\"",
		"db:push": "prisma db push",
		"db:generate": "prisma generate"
	},
	"dependencies": {
		"@discordjs/core": "^2.4.0",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@sapphire/framework": "^5.5.0",
		"@types/ms": "^2.1.0",
		"discord.js": "^14.26.4",
		"dotenv": "^17.4.2",
		"ms": "^2.1.3",
		"prisma": "^7.8.0",
		"sharp": "^0.34.5",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@sapphire/ts-config": "^5.0.3",
		"@types/node": "^22.19.19",
		"@types/sharp": "^0.32.0",
		"concurrently": "^9.2.1",
		"eslint": "^9.39.4",
		"eslint-config-neon": "^0.2.9",
		"eslint-formatter-compact": "^8.40.0",
		"eslint-formatter-pretty": "^7.1.0",
		"prettier": "^3.8.3",
		"rimraf": "^6.1.3",
		"typescript": "~5.9.3"
	},
	"engines": {
		"node": ">=22.12.0"
	},
	"imports": {
		"#utils/*": "./dist/util/*",
		"#lib/*": "./dist/lib/*",
		"#prisma/*": "./dist/generated/prisma/*"
	}
}
