{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "my-bot",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "rimraf dist && tsc",
		"predev": "pnpm build",
