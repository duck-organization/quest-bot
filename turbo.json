{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", "pnpm-lock.yaml"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": [],
      "cache": true
    },
    "format": {
      "outputs": [],
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:generate": {
      "outputs": ["src/generated/**"],
      "cache": true
    },
    "test": {
      "outputs": ["coverage/**"],
      "cache": true
    }
  },
  "remoteCache": {
    "signature": false
  }
}
